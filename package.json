{
  "name": "pterospeed",
  "version": "0.1.0",
  "description": "CLI to analyze and optimize Pterodactyl panel build performance.",
  "license": "MIT",
  "bin": {
    "pterospeed": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
