  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@babel/parser": "^7.28.0",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "diff": "^8.0.2",
    "execa": "^9.6.0",
    "fs-extra": "^11.3.0",
    "ora": "^9.3.0",
    "recast": "^0.23.11"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.15.21",
